# ─────────────────────────────────────────────────────────────────────
# .env 파일 예시 — 실제 .env 는 git 에 commit 하지 마세요 (.gitignore 처리됨)
#
# 사용법:
#   1) 이 파일을 .env 로 복사
#   2) 아래 값들을 환경에 맞게 설정
#   3) serve.py 실행 시 python-dotenv 가 자동 로드
# ─────────────────────────────────────────────────────────────────────

# ── Flask 세션 시크릿 키 (필수)
# 서버 재시작 후에도 세션을 유지하려면 고정값으로 두세요.
# 새로 만들려면: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-secrets-token-hex-32-output

# ── 로그인 게이트 비밀번호 (기본 5361)
LOGIN_PASSWORD=5361

# ── waitress 서버 바인딩
HOST=0.0.0.0
PORT=5051
WAITRESS_THREADS=16

# ── Remote 30 자산 경로 override (옵션 — 기본값은 모듈 디렉토리)
# REMOTE30_TEMPLATE_SDF=C:\path\to\template.sdf
# REMOTE30_STANDARD_SLF=C:\path\to\standard.slf
